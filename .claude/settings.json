{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(git show:*)",
      "Bash(git config --get:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(pip check)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(cat requirements.txt)",
      "Bash(cat README.md)",
      "Bash(cat .gitignore)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(credentials.json)",
      "Read(**/service-account*.json)",
      "Read(**/personal_obsidian/**)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean -fd:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(pip install --force-reinstall:*)",
      "Bash(pip uninstall -y:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-test.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are the stop-verify guardian for the SaveLiveCaptions project. Check the transcript for source code changes in this turn under src/ or tests/. If a .py source file was modified, locate any related test file (tests/test_<module>.py). If such a test exists, invoke the test-guardian agent to run it. If tests fail, return {\"ok\": false, \"reason\": \"<short summary of failure>\"}. If no source files were modified, or if this project has no matching test, return {\"ok\": true}. ALWAYS check the stop_hook_active field — if true, return {\"ok\": true} to prevent infinite loops. Remember: most modules here are Windows-only; if tests fail to collect due to missing winreg/pyaudiowpatch on this platform, that is NOT a real failure — return {\"ok\": true, \"reason\": \"Windows-only module, cannot test on this platform\"}.",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  }
}
